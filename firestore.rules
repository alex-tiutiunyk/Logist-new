rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRole(role) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isDriver() {
      return hasRole('driver');
    }

    function isDispatcher() {
      return hasRole('dispatcher');
    }

    function isLogist() {
      return hasRole('logist');
    }

    function isStaff() {
      return isDispatcher() || isLogist();
    }

    // Users collection
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (request.auth.uid == uid || isStaff());
      allow update: if isAuthenticated() && (
        request.auth.uid == uid || isStaff()
      );
      allow delete: if isLogist();
    }

    // Trips collection
    match /trips/{tripId} {
      allow read: if isAuthenticated();
      allow create: if isStaff();
      allow update: if isAuthenticated() && (
        isStaff() ||
        // Driver can update their own assigned trip
        resource.data.driverUid == request.auth.uid
      );
      allow delete: if isLogist();

      // All trip subcollections (documents, containers, waypoints, statusLog)
      match /{subcollection}/{docId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && (
          isStaff() ||
          (isDriver() && get(/databases/$(database)/documents/trips/$(tripId)).data.driverUid == request.auth.uid)
        );
        allow update: if isAuthenticated() && (
          isStaff() ||
          (isDriver() && get(/databases/$(database)/documents/trips/$(tripId)).data.driverUid == request.auth.uid)
        );
        allow delete: if isStaff();
      }
    }

    // Routes collection (saved route calculations by staff)
    // Public read allowed so shared route links (/r/:id) work without login
    match /routes/{routeId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Route Links collection (client calculator links)
    // Public read allowed so client calculator links (/calc/:linkId) work without login
    match /routeLinks/{linkId} {
      allow read: if true;
      allow write: if isStaff();

      // Calculations subcollection: anyone can read/write (public link, no auth)
      match /calculations/{calcId} {
        allow read, write: if true;
      }
    }

    // Events collection
    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }
  }
}
